# Google Analytics 4 measurement ID (optional override; defaults to G-HHTFX21LZ7)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-HHTFX21LZ7

# Google Search Console site verification (optional override)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=RsJWqjpnVMIU3SqHpcB0q1hBtYQMJ8-4hKhd0ipmfjU

# Microsoft Clarity project ID (optional override; defaults to xf702razyv)
NEXT_PUBLIC_CLARITY_PROJECT_ID=xf702razyv
