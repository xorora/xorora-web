# Losono secret key — set this as an env var on your HOST (Railway/Render/Fly/VPS).
# NEVER commit the real value. ROTATE the key that was shared in chat before using it.
LOSONO_API_KEY=losono_sk_replace_me

# Agent slug/id used in the voice endpoint path.
LOSONO_AGENT_ID=emma

# Comma-separated browser origins allowed to use this relay.
# Leave empty ONLY for local dev (allows all). Always set in production.
ALLOWED_ORIGINS=https://xorora.vercel.app

# Port the proxy listens on (host usually injects its own PORT).
PORT=8787
